# Copy to .env or export in your shell. Never commit real keys.
XAI_API_KEY=xai-REPLACE_ME
XAI_MODEL=grok-4.3
XAI_API_BASE=https://api.x.ai/v1
# Stable UUID improves prefix-cache likelihood for repeated system/schema prompts.
XAI_CACHE_CONV_ID=00000000-0000-4000-8000-000000000000

# Optional independent web-source verifier/context provider.
# Tavily is used for Search/Extract on web URLs; native X posts still rely on xAI x_search.
TAVILY_API_KEY=tvly-REPLACE_ME
TAVILY_API_BASE=https://api.tavily.com
TAVILY_SEARCH_DEPTH=basic
TAVILY_EXTRACT_DEPTH=basic
TAVILY_CONTEXT_CHARS=1200

# Optional Report Intelligence source enhancers. V1 works with public sources first.
HACKERONE_API_USERNAME=
HACKERONE_API_TOKEN=
GITHUB_TOKEN=
BUGCROWD_API_TOKEN=
